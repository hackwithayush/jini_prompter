// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Auth.js (NextAuth) Models
// -----------------------------------------------------------------------------

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  role          String       @default("USER") // USER, PRO, ADMIN, SUPER_ADMIN
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  generations   Generation[]
  memories      Memory[]
  agents        Agent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// JINI Core Models
// -----------------------------------------------------------------------------

model Project {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprints  Blueprint[]
}

model Blueprint {
  id               String   @id @default(cuid())
  projectId        String
  title            String
  rawWish          String
  masterPrompt     String?
  executiveSummary String?
  architecture     String?
  features         String?
  executionPlan    String?
  qualityScore     Float?
  clarityScore     Float?
  structureScore   Float?
  reasoningScore   Float?
  optimizationScore Float?
  conversionScore  Float?
  userRating       Boolean?  // true = Thumbs Up, false = Thumbs Down
  feedbackText     String?
  createdAt        DateTime @default(now())

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Agent {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  avatar        String?
  category      String?
  systemPrompt  String
  personality   String?
  goals         String?  // JSON
  rules         String?  // JSON
  tools         String?  // JSON
  dna           String?  // JSON
  memoryEnabled Boolean  @default(false)
  isTemplate    Boolean  @default(false)
  isPublic      Boolean  @default(false)
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories      AgentMemory[]
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  key       String
  value     String
  category  String?
  embedding String?
  importance Int     @default(1)
  createdAt DateTime @default(now())
  
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Generation {
  id        String   @id @default(cuid())
  userId    String
  input     String
  output    String
  model     String
  tokens    Int?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  category  String?
  embedding String?
  importance Int     @default(1)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
